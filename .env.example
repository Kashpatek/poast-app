# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Upstash Redis (Vercel KV replacement)
# Add a Redis store via Vercel Marketplace, these get set automatically
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Buffer API (for posting schedule and analytics)
# Step 1: Create app at buffer.com/developers/apps/create
# Step 2: Set these three, then use /api/buffer/auth to get the access token
BUFFER_CLIENT_ID=
BUFFER_CLIENT_SECRET=
BUFFER_REDIRECT_URI=https://your-app.vercel.app/api/buffer/callback
# Step 3: After OAuth, paste the token here
BUFFER_ACCESS_TOKEN=
