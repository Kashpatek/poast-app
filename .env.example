# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Upstash Redis (Vercel KV replacement)
# Add a Redis store via Vercel Marketplace, these get set automatically
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Gemini API (for Press to Premier article fetching)
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Buffer API (new GraphQL Beta)
# Get your key at https://publish.buffer.com/settings/api
BUFFER_API_KEY=
