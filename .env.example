# Supabase (database for all app state -- no localStorage)
# Create a project at https://supabase.com, then run supabase-schema.sql in the SQL Editor
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Upstash Redis (Vercel KV replacement)
# Add a Redis store via Vercel Marketplace, these get set automatically
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ElevenLabs (voiceover generation)
# Get your key at https://elevenlabs.io/settings
ELEVENLABS_API_KEY=

# Kling AI (b-roll video generation)
# Get keys from https://platform.klingai.com
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# xAI / Grok (image + video generation, chat)
# Get key from https://console.x.ai
XAI_API_KEY=

# Vercel Blob (for asset uploads in Press to Premier)
# Auto-configured when you add Blob storage in Vercel dashboard
BLOB_READ_WRITE_TOKEN=

# Buffer API (new GraphQL Beta)
# Get your key at https://publish.buffer.com/settings/api
BUFFER_API_KEY=

# Server-only Supabase key (writes bypass RLS) — used by /api/studio + /api/clip
SUPABASE_SERVICE_ROLE_KEY=

# ── Clip Engine (ProductionSTUDIO) ───────────────────────────────
# Cloudflare R2 (S3-compatible) — big-file video storage with zero egress.
# Create a bucket + API token at https://dash.cloudflare.com → R2.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE=            # public read base for clip URLs, e.g. https://pub-xxxx.r2.dev

# External transcription worker (managed Whisper). Runs off-Vercel because
# big-file transcription exceeds the 800s function limit.
WORKER_URL=               # e.g. https://sa-clip-worker.onrender.com
WORKER_SECRET=            # shared secret; signs the /api/clip/callback HMAC
