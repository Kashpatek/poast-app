# SA Clip Worker environment.
# Deploy this folder as its own service (Render / Railway / Fly) — it is NOT
# part of the Vercel build.

# MUST match POAST's WORKER_SECRET — used to verify the inbound request and to
# sign the HMAC on the callback POAST checks.
WORKER_SECRET=

# Transcription provider: "deepgram" (recommended — big files, remote URLs,
# word timestamps) or "openai" (whisper-1, 25 MB/request limit).
TRANSCRIBE_PROVIDER=deepgram
DEEPGRAM_API_KEY=
OPENAI_API_KEY=

PORT=8080
