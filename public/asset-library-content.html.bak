    [data-sa-scope="sa-al0aldn"] .al-rem-body {
      font-size:11px; color:var(--muted); line-height:1.4; margin-top:3px;
    }
    [data-sa-scope="sa-al0aldn"] .al-rem-body b { color:var(--amber); font-weight:700 }
    [data-sa-scope="sa-al0aldn"] .al-rem-tag {
      font-family:'JetBrains Mono', ui-monospace, monospace;
      font-size:9px; font-weight:700; letter-spacing:.14em; text-transform:uppercase;
