    [data-sa-scope="sa-al0aldn"] .al-pv-foot {
      display:flex; align-items:center; gap:10px;
      margin-top:10px; padding-top:9px;
      border-top:1px dashed rgba(255,255,255,.06);
      font-family:'JetBrains Mono', ui-monospace, monospace;
      font-size:9.5px; color:var(--muted2); letter-spacing:.04em;
    }
    [data-sa-scope="sa-al0aldn"] .al-pv-foot .sep { opacity:.4 }
    [data-sa-scope="sa-al0aldn"] .al-pv-foot .open {
      margin-left:auto; color:var(--amber); font-weight:700; letter-spacing:.08em; text-transform:uppercase;
      text-decoration:none; transition:filter .15s, transform .15s;
    }
    [data-sa-scope="sa-al0aldn"] .al-pv-foot a.open:hover { filter:brightness(1.15); transform:translateX(2px) }

    /* Folder grid · shows mini cards for items in a folder */
    [data-sa-scope="sa-al0aldn"] .al-pv-folder {
      position:relative; z-index:2;
      width:100%; max-width:420px;
    }
    [data-sa-scope="sa-al0aldn"] .al-pv-folder-head {
      display:flex; align-items:center; gap:9px;
      padding:6px 8px; border-radius:8px;
      text-decoration:none; color:inherit;
      transition:background .15s, transform .15s;
    }
    [data-sa-scope="sa-al0aldn"] .al-pv-folder-head.linked { cursor:pointer }
    [data-sa-scope="sa-al0aldn"] .al-pv-folder-head.linked:hover {
      background:rgba(247,176,65,.07);
      transform:translateY(-1px);
    }
    [data-sa-scope="sa-al0aldn"] .al-pv-folder-link {
      flex:none; color:var(--amber); opacity:.75;
      font-family:'JetBrains Mono', ui-monospace, monospace;
      font-size:13px; font-weight:700;
      transition:transform .2s, opacity .2s;
    }
    [data-sa-scope="sa-al0aldn"] .al-pv-folder-head.linked:hover .al-pv-folder-link {
      opacity:1; transform:translateX(2px) translateY(-1px);
    }
    [data-sa-scope="sa-al0aldn"] .al-pv-folder-ic {
      width:30px; height:30px; flex:none;
      background:rgba(247,176,65,.14);
      border:1px solid rgba(247,176,65,.32);
