      filter:drop-shadow(0 2px 8px rgba(0,0,0,.4));
    }
    [data-sa-scope="sa-al0aldn"] .al-pv-bg-tag {
      font-family:'JetBrains Mono', ui-monospace, monospace;
      font-size:8.5px; font-weight:700; letter-spacing:.06em;
