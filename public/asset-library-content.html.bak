      border-bottom:1px solid rgba(255,255,255,.05);
    }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini img { padding:6px }
    /* Scale internal mocks for mini · ratios kept, paddings + font sizes shrunk */
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-glyph { font-size:32px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini.kind-font .al-pv-glyph { font-size:38px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-font-stack { gap:10px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-font-stack .al-pv-glyph { font-size:24px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini.kind-template { padding:8px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-template-mock { padding:5px; gap:4px; width:84%; height:80% }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini.kind-sheet { padding:8px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-sheet-mock { padding:5px; gap:4px; width:92%; height:88% }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-sheet-tabs { height:5px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-sheet-tabs i:nth-child(1) { flex:0 0 14px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-sheet-tabs i:nth-child(2) { flex:0 0 14px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-sheet-panes { gap:4px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-sheet-chart { padding:3px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini.kind-doc { padding:8px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-doc-mock { width:62%; height:84%; padding:6px 5px; gap:3px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-doc-mock i { height:2px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-doc-mock i:nth-child(1) { height:3px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini.kind-cheat { padding:8px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-cheat-mock { width:84%; height:84%; gap:3px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-cheat-mock i.t { height:7px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-cheat-mock .s { height:7px; gap:2px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-cheat-mock .g { gap:3px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-skill { gap:7px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-skill .sk-glyph { font-size:24px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-skill .sk-text { font-size:13px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-skill .sk-pulse { width:6px; height:6px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-bg { max-height:78px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-bg-glyph { font-size:14px }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.mini .al-pv-bg-tag { display:none }

    /* Excel · Light variant (white workbook with same SA chart colors) */
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.kind-sheet.light {
      background:linear-gradient(160deg, #ECECEF 0%, #D9DADD 100%);
    }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.kind-sheet.light .al-pv-sheet-mock {
      background:#fff;
      border-color:rgba(0,0,0,.08);
      box-shadow:inset 0 1px 0 rgba(0,0,0,.03), 0 4px 12px -6px rgba(0,0,0,.12);
    }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.kind-sheet.light .al-pv-sheet-tabs i:nth-child(1) { background:#F7B041; box-shadow:inset 0 -2px 0 #D89A38 }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.kind-sheet.light .al-pv-sheet-tabs i:nth-child(2) { background:#0B86D1 }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.kind-sheet.light .al-pv-sheet-tabs i:nth-child(3) { background:rgba(0,0,0,.04) }
    [data-sa-scope="sa-al0aldn"] .al-pv-thumb.kind-sheet.light .al-pv-sheet-chart {
      background:rgba(0,0,0,.03);
      border-color:rgba(0,0,0,.06);
      filter:none;
    }
    [data-sa-scope="sa-al0aldn"] .al-pv-mini-name {
      padding:7px 9px;
      font-family:'Outfit', sans-serif;
      font-size:11.5px; font-weight:600;
      color:var(--text);
      white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
    }
    [data-sa-scope="sa-al0aldn"] .al-pv-mini-ext {
      padding:0 9px 8px;
      font-family:'JetBrains Mono', ui-monospace, monospace;
      font-size:8.5px; color:var(--muted2); letter-spacing:.06em;
    }

    /* Active leaf in tree */
    [data-sa-scope="sa-al0aldn"] .al-leaf.al-active {
      background:rgba(247,176,65,.13) !important;
      color:var(--amber) !important;
      box-shadow:inset 2px 0 0 var(--amber);
    }
    [data-sa-scope="sa-al0aldn"] .al-leaf.al-active::before { opacity:1 }

    /* Reminders strip · sits above the Slack box */
    [data-sa-scope="sa-al0aldn"] .al-rem {
      display:grid; grid-template-columns:1fr 1fr; gap:11px;
      margin-top:12px;
    }
    [data-sa-scope="sa-al0aldn"] .al-rem-card {
      display:flex; align-items:center; gap:11px;
      padding:9px 13px;
      background:linear-gradient(135deg, rgba(255,255,255,.025) 0%, rgba(255,255,255,.008) 100%);
      border:1px solid var(--border2);
      border-radius:10px;
      transition:transform .25s, border-color .25s, background .25s;
      cursor:pointer;
    }
    [data-sa-scope="sa-al0aldn"] .al-rem-card:hover {
      transform:translateY(-1px);
      border-color:rgba(247,176,65,.3);
      background:linear-gradient(135deg, rgba(247,176,65,.04) 0%, rgba(247,176,65,.01) 100%);
    }
    [data-sa-scope="sa-al0aldn"] .al-rem-ic {
      width:34px; height:34px; flex:none;
      display:flex; align-items:center; justify-content:center;
      border-radius:8px;
      background:rgba(247,176,65,.12);
      border:1px solid rgba(247,176,65,.25);
      color:var(--amber);
      font-size:15px;
      box-shadow:inset 0 1px 0 rgba(255,255,255,.06);
    }
    [data-sa-scope="sa-al0aldn"] .al-rem-card.mode .al-rem-ic {
      background:linear-gradient(135deg, rgba(247,176,65,.18) 0%, rgba(11,134,209,.18) 100%);
      border-color:rgba(247,176,65,.3);
      font-size:12px;
      letter-spacing:0;
    }
    [data-sa-scope="sa-al0aldn"] .al-rem-mode-glyph {
      display:inline-flex; align-items:center; gap:3px;
      font-family:'JetBrains Mono', ui-monospace, monospace;
      font-weight:700;
    }
    [data-sa-scope="sa-al0aldn"] .al-rem-mode-glyph .sun  { animation:alSunPulse 3.4s ease-in-out infinite }
    [data-sa-scope="sa-al0aldn"] .al-rem-mode-glyph .moon { animation:alMoonPulse 3.4s ease-in-out infinite 1.7s }
    @keyframes alSunPulse  { 0%,100% { opacity:1; filter:drop-shadow(0 0 4px rgba(247,176,65,.6)) } 50% { opacity:.5; filter:drop-shadow(0 0 0 transparent) } }
    @keyframes alMoonPulse { 0%,100% { opacity:.5; filter:drop-shadow(0 0 0 transparent) } 50% { opacity:1; filter:drop-shadow(0 0 4px rgba(180,200,255,.6)) } }
    [data-sa-scope="sa-al0aldn"] .al-rem-card.fonts .al-rem-ic { color:var(--amber) }
    [data-sa-scope="sa-al0aldn"] .al-rem-card.fonts .al-rem-ic svg { animation:alDownBob 2.2s ease-in-out infinite }
    @keyframes alDownBob { 0%,100% { transform:translateY(0) } 50% { transform:translateY(2px) } }
    [data-sa-scope="sa-al0aldn"] .al-rem-text { flex:1; min-width:0 }
    [data-sa-scope="sa-al0aldn"] .al-rem-title {
      font-family:'Outfit', sans-serif; font-size:13px; font-weight:700;
      color:var(--text); letter-spacing:.005em; line-height:1.2;
