    }

    /* Slack strip */
    [data-sa-scope="sa-al0aldn"] .al-slack {
      margin-top:11px;
      display:flex; align-items:center; gap:14px;
      padding:10px 16px;
      background:linear-gradient(135deg, rgba(74,21,75,.55) 0%, rgba(54,16,55,.25) 100%);
      border:1px solid rgba(195,140,200,.28);
      border-radius:11px;
      box-shadow:0 12px 28px -16px rgba(74,21,75,.5), inset 0 1px 0 rgba(255,255,255,.05);
      transition:transform .25s, border-color .25s, box-shadow .25s;
      cursor:pointer;
    }
    [data-sa-scope="sa-al0aldn"] .al-slack:hover { transform:translateY(-1px); border-color:rgba(195,140,200,.5); box-shadow:0 16px 36px -16px rgba(74,21,75,.7), inset 0 1px 0 rgba(255,255,255,.06) }
    [data-sa-scope="sa-al0aldn"] .al-slack-ic {
      width:30px; height:30px; flex:none;
      background:linear-gradient(135deg, #4A154B 0%, #611f5f 100%);
      border-radius:7px;
      display:flex; align-items:center; justify-content:center;
      color:#fff; font-weight:700; font-size:17px; line-height:1;
      box-shadow:inset 0 1px 0 rgba(255,255,255,.18), 0 4px 12px rgba(74,21,75,.5);
    }
    [data-sa-scope="sa-al0aldn"] .al-slack-text { display:flex; flex-direction:column; gap:1px; min-width:0 }
    [data-sa-scope="sa-al0aldn"] .al-slack-label {
      font-family:'JetBrains Mono', ui-monospace, monospace;
      font-size:9px; font-weight:700; letter-spacing:.16em; text-transform:uppercase;
      color:rgba(255,255,255,.55);
    }
    [data-sa-scope="sa-al0aldn"] .al-slack-chan {
      font-family:'Outfit', sans-serif; font-size:14px; color:var(--text); font-weight:500;
    }
    [data-sa-scope="sa-al0aldn"] .al-slack-chan b { color:var(--amber); font-weight:700 }
    [data-sa-scope="sa-al0aldn"] .al-slack-arrow {
      margin-left:auto; color:var(--muted2); font-size:18px;
      transition:transform .22s, color .22s;
    }
    [data-sa-scope="sa-al0aldn"] .al-slack:hover .al-slack-arrow { color:var(--amber); transform:translateX(4px) }

    /* Entrance */
    @keyframes alIn { 0% { opacity:0; transform:translateY(18px) } 100% { opacity:1; transform:translateY(0) } }
    [data-sa-scope="sa-al0aldn"] .eyebrow,
    [data-sa-scope="sa-al0aldn"] .slide-title,
    [data-sa-scope="sa-al0aldn"] .slide-sub,
    [data-sa-scope="sa-al0aldn"] .al-tree,
    [data-sa-scope="sa-al0aldn"] .al-dir,
    [data-sa-scope="sa-al0aldn"] .al-rem-card,
    [data-sa-scope="sa-al0aldn"] .al-slack { opacity:0 }
    [data-sa-scope="sa-al0aldn"].on .eyebrow     { animation:alIn .5s ease both .1s }
    [data-sa-scope="sa-al0aldn"].on .slide-title { animation:alIn .55s cubic-bezier(.22,.9,.32,1) both .22s }
    [data-sa-scope="sa-al0aldn"].on .slide-sub   { animation:alIn .5s ease both .35s }
    [data-sa-scope="sa-al0aldn"].on .al-tree     { animation:alIn .55s cubic-bezier(.22,.9,.32,1) both .5s }
    [data-sa-scope="sa-al0aldn"].on .al-dir      { animation:alIn .55s cubic-bezier(.22,.9,.32,1) both .65s }
    [data-sa-scope="sa-al0aldn"].on .al-rem-card:nth-child(1) { animation:alIn .5s cubic-bezier(.22,.9,.32,1) both .78s }
    [data-sa-scope="sa-al0aldn"].on .al-rem-card:nth-child(2) { animation:alIn .5s cubic-bezier(.22,.9,.32,1) both .88s }
    [data-sa-scope="sa-al0aldn"].on .al-slack    { animation:alIn .5s ease both 1s }
  </style>

