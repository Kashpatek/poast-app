  <div class="al-slack">
    <div class="al-slack-ic">#</div>
    <div class="al-slack-text">
      <div class="al-slack-label">Where to find it on Slack</div>
      <div class="al-slack-chan"><b>#marketing</b> → pinned: <b>Brand Kit</b></div>
    </div>
    <div class="al-slack-arrow">→</div>
  </div>

  <script>
  /* Asset Library preview · clicking tree items swaps the right pane */
  (() => {
    const root = document.querySelector('[data-sa-scope="sa-al0aldn"]');
    if (!root || root.dataset.alWired === '1') return;
    root.dataset.alWired = '1';
    const stage = root.querySelector('.al-stage');
    if (!stage) return;

    const esc = s => String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));

    // Asset registry · `thumb` is the path to a screenshot; null falls back to a creative generated thumb
    const FILES = {
      // Logo Set · 4 files (mapped to actual SVGs in /brand/Logo Set/)
      'logo-primary':  { name:'Box Logo + Text', exts:['SVG','PNG'], size:'4 KB', updated:'this week', kind:'logo', glyph:'SA', desc:'Full SemiAnalysis lockup. Use on light or dark surfaces; keep clear-space equal to the lettermark height.', thumb:'/brand/Logo%20Set/SVG/Box%20Logo%20%2B%20Text.svg' },
      'logo-letter':   { name:'Lettermark', exts:['SVG','PNG'], size:'1.2 KB', updated:'this week', kind:'logo', glyph:'SA', desc:'Compact "SA" mark. Used as the corner brand on every slide and the favicon.', thumb:'/brand/Logo Set/SVG/Lettermark.svg' },
      'logo-box':      { name:'Box Logo', exts:['SVG','PNG'], size:'2 KB', updated:'this week', kind:'logo', glyph:'sa', desc:'Stand-alone box monogram. Use for social avatars, tight square spots, or anywhere a single solid mark lands harder than the lockup.', thumb:'/brand/Logo Set/SVG/Box Logo.svg' },
      'logo-combined': { name:'Box Logo + Lettermark', exts:['SVG','PNG'], size:'3 KB', updated:'this week', kind:'logo', glyph:'⤳', desc:'Box logo paired with the lettermark for tight horizontal lockups — slide footers, signatures, narrow headers.', thumb:'/brand/Logo%20Set/Full%20Size/Box%20Logo%20%2B%20Lettermark.png' },

      // Fonts · 4 (master archive + 3 individual)
      'font-master': { name:'2026 BRANDFONTS.zip', exts:['ZIP'], size:'1.1 MB', updated:'last month', kind:'font', subkind:'master', desc:'Master archive with all three brand fonts — install once and you get Outfit, Aptos, and Grift.', thumb:null },
      'font-outfit': { name:'Outfit', exts:['ZIP','OTF','WEB'], size:'380 KB', updated:'last month', kind:'font', glyph:'Aa', subkind:'outfit', desc:'Display + body sans. Headlines, slide titles, button labels — nearly everything visual on the brand.', thumb:null },
      'font-aptos':  { name:'Aptos',  exts:['ZIP','OTF'], size:'420 KB', updated:'last month', kind:'font', glyph:'Aa', subkind:'aptos',  desc:"Microsoft's default office sans. Letterhead, Excel, and anywhere Word/Excel are home.", thumb:null },
      'font-grift':  { name:'Grift',  exts:['ZIP','OTF'], size:'320 KB', updated:'last month', kind:'font', glyph:'Aa', subkind:'grift',  desc:'Editorial display serif for accent moments — feature headlines, pull quotes, awards. Graphics use only.', thumb:null },

      // PowerPoint · 4 (Outfit + Aptos × Dark/Light)
      'ppt-outfit-dark':  { name:'Full Deck · Dark · Outfit',  exts:['PPTX'], size:'24 MB', updated:'this week', kind:'template', subkind:'dark',  desc:'Dark master deck in Outfit. Section dividers, content layouts, and brand chrome pre-wired.', thumb:'/brand/SA DECK DARK OUTFIT FULL Dark.jpg' },
      'ppt-outfit-light': { name:'Full Deck · Light · Outfit', exts:['PPTX'], size:'24 MB', updated:'this week', kind:'template', subkind:'light', desc:'Light counterpart of the Outfit deck for client-facing decks and projectors.', thumb:'/brand/SA DECK DARK OUTFIT FULL Light.jpg' },
      'ppt-aptos-dark':   { name:'Full Deck · Dark · Aptos',   exts:['PPTX'], size:'26 MB', updated:'this week', kind:'template', subkind:'dark',  desc:'Aptos-set dark deck for office contexts and Microsoft-native audiences.', thumb:null },
      'ppt-aptos-light':  { name:'Full Deck · Light · Aptos',  exts:['PPTX'], size:'26 MB', updated:'this week', kind:'template', subkind:'light', desc:'Light Aptos deck. Office-friendly, projector-friendly, client-ready.', thumb:null },

      // Excel · 2 (Outfit + Aptos, both with light + dark sheets inside)
      'xls-outfit': { name:'Workbook · Outfit', exts:['XLSX'], size:'1.8 MB', updated:'this week', kind:'sheet', subkind:'light', desc:'Master workbook with the Spectrum chart palette + PNG export preset. Light and dark sheets in the same file. Outfit-typed — preview shows the light face.', thumb:null },
      'xls-aptos':  { name:'Workbook · Aptos',  exts:['XLSX'], size:'1.8 MB', updated:'this week', kind:'sheet', desc:'Aptos counterpart of the master workbook. Same charts, font native to Excel — preview shows the dark face.', thumb:null },

      // Letterheads · 9 (Style A × 4 + Style B × 4 + Fillable PDF · backdrop PNGs as thumbs)
      'lh-a-dark-outfit':  { name:'Letterhead A · Dark · Outfit',  exts:['DOCX'], size:'320 KB', updated:'new', kind:'doc', desc:'Style A header layout, dark mode, Outfit set. Use for external letters and partner correspondence.', thumb:'/brand/letterhead-backdrops/A_dark_glow.png' },
      'lh-a-light-outfit': { name:'Letterhead A · Light · Outfit', exts:['DOCX'], size:'320 KB', updated:'new', kind:'doc', desc:'Style A header layout, light mode, Outfit set.', thumb:'/brand/letterhead-backdrops/A_light_glow.png' },
      'lh-a-dark-aptos':   { name:'Letterhead A · Dark · Aptos',   exts:['DOCX'], size:'320 KB', updated:'new', kind:'doc', desc:'Style A header layout, dark mode, Aptos set for Office contexts.', thumb:'/brand/letterhead-backdrops/A_dark_basic.png' },
      'lh-a-light-aptos':  { name:'Letterhead A · Light · Aptos',  exts:['DOCX'], size:'320 KB', updated:'new', kind:'doc', desc:'Style A header layout, light mode, Aptos set for Office contexts.', thumb:'/brand/letterhead-backdrops/A_light_basic.png' },
      'lh-b-dark-outfit':  { name:'Letterhead B · Dark · Outfit',  exts:['DOCX'], size:'320 KB', updated:'new', kind:'doc', desc:'Style B header layout, dark mode, Outfit set. Tighter header than Style A — best for short-form letters.', thumb:'/brand/letterhead-backdrops/B_dark_glow.png' },
      'lh-b-light-outfit': { name:'Letterhead B · Light · Outfit', exts:['DOCX'], size:'320 KB', updated:'new', kind:'doc', desc:'Style B header layout, light mode, Outfit set.', thumb:'/brand/letterhead-backdrops/B_light_glow.png' },
      'lh-b-dark-aptos':   { name:'Letterhead B · Dark · Aptos',   exts:['DOCX'], size:'320 KB', updated:'new', kind:'doc', desc:'Style B header layout, dark mode, Aptos set.', thumb:'/brand/letterhead-backdrops/B_dark_basic.png' },
      'lh-b-light-aptos':  { name:'Letterhead B · Light · Aptos',  exts:['DOCX'], size:'320 KB', updated:'new', kind:'doc', desc:'Style B header layout, light mode, Aptos set.', thumb:'/brand/letterhead-backdrops/B_light_basic.png' },
      'lh-pdf':            { name:'SA Letterhead Fillable',        exts:['PDF'],  size:'180 KB', updated:'this week', kind:'doc', desc:'Fillable PDF letterhead — signed forms, agreements, anywhere a non-Word recipient needs the brand.', thumb:null },

      // Social Backdrops · 4 sets (each leaf = a backdrop set; closer hero shown as preview)
      'bg-internal':  { name:'Internal · Amber',         exts:['JPG'], size:'4 sizes', updated:'this week', kind:'image', subkind:'bg-internal', desc:'Warm amber backdrop set for internal-facing posts. 4 ratio variants per set.', thumb:'/brand/social/internal-amber/Y4 - Close@3x-100.jpg' },
      'bg-external':  { name:'External · Cobalt',        exts:['JPG'], size:'4 sizes', updated:'this week', kind:'image', subkind:'bg-external', desc:'Cool cobalt backdrop set for external press, partners, and media.', thumb:'/brand/social/external-cobalt/B4 - Closer.jpg' },
      'bg-general':   { name:'General · Cobalt + Amber', exts:['JPG'], size:'4 sizes', updated:'this week', kind:'image', subkind:'bg-general',  desc:'Brand split set — cobalt + amber together. Default backdrop for any general-purpose post.', thumb:'/brand/social/general-cobalt-amber/YB4 - Closer@3x-100.jpg' },
      'bg-capital':   { name:'Capital · Mint',           exts:['JPG'], size:'4 sizes', updated:'this week', kind:'image', subkind:'bg-capital',   desc:'Mint backdrop set for capital-related and finance-themed posts.', thumb:'/brand/social/capital-mint/G4 - Closer@3x-100.jpg' },

      // Brand & Guidelines · 3
      'cheat-dark':  { name:'Brand Cheat Sheet · Dark',  exts:['PNG'], size:'440 KB', updated:'this week', kind:'cheat', subkind:'dark',  desc:'One-page brand reference: logos, palette, type ramp, dos and donts. Dark variant.', thumb:'/brand/guidelines/cheatsheet-dark.png' },
      'cheat-light': { name:'Brand Cheat Sheet · Light', exts:['PNG'], size:'428 KB', updated:'this week', kind:'cheat', subkind:'light', desc:'Light counterpart of the cheat sheet for printing on white or sharing in Slack.', thumb:'/brand/guidelines/cheatsheet-light.png' },
      'brand-guide': { name:'SemiAnalysis Brand Guide',  exts:['PDF'], size:'852 KB', updated:'this week', kind:'doc',                    desc:'The full brand guide PDF — logo usage, color spec, typography, voice, and approval workflow.', thumb:null },

      // Skills & Themes · 5 Claude skills + 2 Office (Windows) themes
      'skill-brand-system': { name:'sa-brand-system',          exts:['SKILL'], size:'live', updated:'always check', kind:'skill', desc:'Master skill that loads the SA brand voice + visual system into Claude. Start here for any new project.', thumb:null },
      'skill-charts':       { name:'sa-core-charts',           exts:['SKILL'], size:'live', updated:'always check', kind:'skill', desc:'Drafts on-brand charts using the Spectrum palette and SA chart conventions.', thumb:null },
      'skill-dark-convert': { name:'sa-dark-outfit-convert',   exts:['SKILL'], size:'live', updated:'always check', kind:'skill', desc:'Converts existing decks to the dark Outfit master.', thumb:null },
      'skill-letterhead':   { name:'sa-letterhead-system',     exts:['SKILL'], size:'live', updated:'always check', kind:'skill', desc:'Authors letterhead documents with the right header, footer, and View → Switch Modes wiring.', thumb:null },
      'skill-style':        { name:'sa-style-template',        exts:['SKILL'], size:'live', updated:'always check', kind:'skill', desc:'Ensures any new visual template (slide, doc, post) snaps to the brand spec.', thumb:null },
      'theme-spectrum':     { name:'SA Spectrum · Office theme', exts:['THMX'], size:'~120 KB', updated:'new', kind:'doc', desc:'Windows / Microsoft Office theme using the SA Spectrum palette. Apply via Page Layout → Themes in Word, Excel, or PowerPoint.', thumb:null },
      'theme-core':         { name:'SA Core · Office theme',     exts:['THMX'], size:'~120 KB', updated:'new', kind:'doc', desc:'Windows / Microsoft Office theme using SA core colors (amber + cobalt). Quickest way to brand a one-off Office doc.', thumb:null }

    };

    const ROOT_URL = 'https://semianalysis.sharepoint.com/:f:/s/SemiAnalysisTeam/IgBz5Mg50M1NQ5us3Yytzu_3AT8_OrWtFfSKeBfsZbdEaec?e=QKwikD';

    const FOLDERS = {
      'logos':       { name:'Logo Set',             count:'4 files', url:'https://semianalysis.sharepoint.com/:f:/s/SemiAnalysisTeam/IgAE39ed2uusSo4HFYT6o7ayAbT1FjS3k-x86_GVublyeqM?e=ndBwlx', items:['logo-primary','logo-letter','logo-box','logo-combined'] },
      'fonts':       { name:'Fonts',                count:'4 items', url:'https://semianalysis.sharepoint.com/:f:/s/SemiAnalysisTeam/IgDIGCgnk4U5TqgaKJCh4bmqAc-As3QpS2DVtGSZEylMURs?e=Ehxnpn', items:['font-master','font-outfit','font-aptos','font-grift'] },
      'ppt':         { name:'PowerPoint Templates', count:'4 files', url:'https://semianalysis.sharepoint.com/:f:/s/SemiAnalysisTeam/IgD8ZmtMQLjjSqzob0K6NJGKAanQ5zmvH0ZFrbOWGdQ8wYI?e=lIL3NJ', items:['ppt-outfit-dark','ppt-outfit-light','ppt-aptos-dark','ppt-aptos-light'] },
      'excel':       { name:'Excel Templates',      count:'2 files', url:'https://semianalysis.sharepoint.com/:f:/s/SemiAnalysisTeam/IgBQBBjl3KcESYk-X8zMTGetAeB4USCXK31p0sA3gtUpnB8?e=VLA94W', items:['xls-outfit','xls-aptos'] },
      'letterheads': { name:'Letterheads',          count:'9 files', url:'https://semianalysis.sharepoint.com/:f:/s/SemiAnalysisTeam/IgAk8uid3xruSZiUdDRRlrQfAZprhN4siIPYesNGJrx4gK0?e=ZZeSVg', items:['lh-a-dark-outfit','lh-a-light-outfit','lh-a-dark-aptos','lh-a-light-aptos','lh-b-dark-outfit','lh-b-light-outfit','lh-b-dark-aptos','lh-b-light-aptos','lh-pdf'] },
      'social-bg':   { name:'Social Backdrops',     count:'4 sets',  url:'https://semianalysis.sharepoint.com/:f:/s/SemiAnalysisTeam/IgDoO1Bu3kDgQ5ABEcCeoGaUAaQ9xM474fGa0cw5MqUkbvU?e=GZE1Tg', items:['bg-internal','bg-external','bg-general','bg-capital'] },
      'guidelines':    { name:'Brand & Guidelines', count:'3 files', url:'https://semianalysis.sharepoint.com/:f:/r/sites/SemiAnalysisTeam/Shared%20Documents/Logos%20and%20Art/2026%20Brand%20Launch/Brand%20and%20Guidelines?csf=1&web=1&e=tPOCRN', items:['cheat-dark','cheat-light','brand-guide'] },
      'skills-themes': { name:'Skills & Themes',    count:'7 files', url:'https://semianalysis.sharepoint.com/:f:/s/SemiAnalysisTeam/IgCumajjw3LcQYumgjLATGt8AckED4LOzcgLuZczSt2qsO8?e=nCq9Ji', items:['skill-brand-system','skill-charts','skill-dark-convert','skill-letterhead','skill-style','theme-spectrum','theme-core'] }
    };

    // Build a key→folder lookup so file footers can link to their parent folder
    const PARENT_FOLDER = {};
    for (const fk of Object.keys(FOLDERS)) for (const k of FOLDERS[fk].items) PARENT_FOLDER[k] = fk;

    const BG_GLYPH = { 'bg-x':'𝕏', 'bg-ig-square':'IG', 'bg-ig-portrait':'IG', 'bg-story':'◫', 'bg-linkedin':'in' };
    const BG_AR    = { 'bg-x':'16/9', 'bg-ig-square':'1/1', 'bg-ig-portrait':'4/5', 'bg-story':'9/16', 'bg-linkedin':'1.91/1' };

    function thumbHTML(f) {
      if (f.thumb) return `<img src="${esc(f.thumb)}" alt="${esc(f.name)}">`;
      if (f.kind === 'color') return `<div class="al-pv-color-strip">${(f.swatches || []).map(c => `<span style="background:${esc(c)}"></span>`).join('')}</div>`;
      if (f.kind === 'image' && f.subkind && f.subkind.startsWith('bg-')) {
        return `<div class="al-pv-bg" style="aspect-ratio:${BG_AR[f.subkind] || '16/9'}"><span class="al-pv-bg-glyph">${esc(BG_GLYPH[f.subkind] || '◯')}</span><span class="al-pv-bg-tag">${esc(f.size || '')}</span></div>`;
      }
      if (f.kind === 'image') {
        const palette = ['#F7B041','#0B86D1','#2EAD8E','#E06347','#9C6CC9','#5F88D4'];
        return `<div class="al-pv-mosaic">${palette.map(c => `<span style="background:${c}"></span>`).join('')}</div>`;
      }
      if (f.kind === 'template') return `<div class="al-pv-template-mock"><i></i><i></i><i></i><i></i><i></i><i></i></div>`;
      if (f.kind === 'sheet') return `
        <div class="al-pv-sheet-mock">
          <div class="al-pv-sheet-tabs"><i></i><i></i><i></i></div>
          <div class="al-pv-sheet-panes">
            <svg class="al-pv-sheet-chart" viewBox="0 0 100 60" preserveAspectRatio="none" aria-hidden="true">
              <rect x="4"  y="34" width="14" height="26" fill="#F7B041" rx="1"/>
              <rect x="22" y="18" width="14" height="42" fill="#E06347" rx="1"/>
              <rect x="40" y="42" width="14" height="18" fill="#9C6CC9" rx="1"/>
              <rect x="58" y="10" width="14" height="50" fill="#0B86D1" rx="1"/>
              <rect x="76" y="28" width="14" height="32" fill="#2EAD8E" rx="1"/>
            </svg>
            <svg class="al-pv-sheet-chart" viewBox="0 0 100 60" preserveAspectRatio="none" aria-hidden="true">
              <polyline points="0,42 20,32 40,36 60,16 80,22 100,8"   stroke="#F7B041" stroke-width="2.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              <polyline points="0,52 20,46 40,40 60,32 80,28 100,18"  stroke="#0B86D1" stroke-width="2.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              <polyline points="0,55 20,52 40,48 60,42 80,38 100,30"  stroke="#2EAD8E" stroke-width="2.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>`;
      if (f.kind === 'doc')      return `<div class="al-pv-doc-mock"><i></i><i></i><i></i><i></i><i></i></div>`;
      if (f.kind === 'cheat')    return `<div class="al-pv-cheat-mock"><i class="t"></i><div class="g"><i></i><i></i><i></i><i></i><i></i><i></i></div><div class="s"><span></span><span></span><span></span><span></span><span></span></div></div>`;
      if (f.kind === 'skill')    return `<div class="al-pv-skill"><span class="sk-pulse"></span><span class="sk-glyph">✦</span><span class="sk-text">.skill</span></div>`;
      if (f.kind === 'font' && f.subkind === 'master') {
        return `<div class="al-pv-font-stack"><span class="al-pv-glyph outfit">Aa</span><span class="al-pv-glyph aptos">Aa</span><span class="al-pv-glyph grift">Aa</span></div>`;
      }
      const cls = f.kind === 'font' ? `al-pv-glyph ${f.subkind || ''}` : 'al-pv-glyph';
      return `<span class="${cls}">${esc(f.glyph || '◇')}</span>`;
    }

    // Reuse the full thumb renderer for folder-grid minis · CSS .mini scales it down
    function miniThumbHTML(f) { return thumbHTML(f); }

    const ONEDRIVE_ICON = '<svg width="14" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="vertical-align:-1px;margin-right:6px"><path d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z"/></svg>';

    function renderFile(key) {
      const f = FILES[key]; if (!f) return '';
      const sub = f.subkind ? ` ${esc(f.subkind)}` : '';
      const parent = FOLDERS[PARENT_FOLDER[key]];
      const parentUrl = parent && parent.url;
      const ctaText = f.kind === 'skill' ? 'Pull latest from Claude ↗' : `${ONEDRIVE_ICON}Open on OneDrive`;
      const cta = parentUrl
        ? `<a class="open" href="${esc(parentUrl)}" target="_blank" rel="noopener">${ctaText}</a>`
        : `<span class="open">${ctaText}</span>`;
      return `
        <div class="al-pv-card">
          <div class="al-pv-thumb kind-${esc(f.kind)}${sub}">${thumbHTML(f)}</div>
          <div class="al-pv-meta">
            <div class="al-pv-row">
              <div class="al-pv-name">${esc(f.name)}</div>
              ${(f.exts || []).map(e => `<span class="al-pv-ext">${esc(e)}</span>`).join('')}
            </div>
            <div class="al-pv-desc">${esc(f.desc || '')}</div>
            <div class="al-pv-foot">
              <span>${esc(f.size || '')}</span><span class="sep">·</span>
              <span>updated ${esc(f.updated || '')}</span>
              ${cta}
            </div>
          </div>
        </div>`;
    }

    function renderFolder(key) {
      const F = FOLDERS[key]; if (!F) return '';
      const headOpen = F.url
        ? `<a class="al-pv-folder-head linked" href="${esc(F.url)}" target="_blank" rel="noopener" title="Open in OneDrive">`
        : `<div class="al-pv-folder-head">`;
      const headClose = F.url ? '</a>' : '</div>';
      return `
        <div class="al-pv-folder">
          ${headOpen}
            <div class="al-pv-folder-ic">▣</div>
            <div class="al-pv-folder-name">${esc(F.name)}</div>
            <div class="al-pv-folder-count">${esc(F.count)}</div>
            ${F.url ? '<span class="al-pv-folder-link">↗</span>' : ''}
          ${headClose}
          <div class="al-pv-grid">
            ${F.items.map(k => {
              const f = FILES[k]; if (!f) return '';
              const sub = f.subkind ? ` ${esc(f.subkind)}` : '';
              return `
                <div class="al-pv-mini" data-asset="${esc(k)}">
                  <div class="al-pv-thumb mini kind-${esc(f.kind)}${sub}">${miniThumbHTML(f)}</div>
                  <div class="al-pv-mini-name">${esc(f.name)}</div>
                  <div class="al-pv-mini-ext">${(f.exts || []).join(' · ')}</div>
                </div>`;
            }).join('')}
          </div>
        </div>`;
    }

    function setActive(key) {
      root.querySelectorAll('.al-leaf').forEach(el => el.classList.toggle('al-active', el.dataset.asset === key));
    }

    function swap(html, state) {
      stage.classList.add('swapping');
      setTimeout(() => {
        stage.dataset.state = state;
        stage.classList.remove('overflowing');
        stage.innerHTML = html;
        stage.scrollTop = 0;
        stage.classList.remove('swapping');
        // Wire mini cards inside folder previews
        stage.querySelectorAll('.al-pv-mini').forEach(m => {
          m.addEventListener('click', () => showFile(m.dataset.asset));
        });
        // After layout settles, switch to top-aligned scroll if content overflows; otherwise stay centred
        requestAnimationFrame(() => {
          if (stage.scrollHeight > stage.clientHeight + 1) stage.classList.add('overflowing');
        });
      }, 200);
    }

    function showFile(key) { if (!FILES[key]) return; setActive(key); swap(renderFile(key), 'file'); }
    function showFolder(key) { if (!FOLDERS[key]) return; setActive(null); swap(renderFolder(key), 'folder'); }

    root.querySelectorAll('.al-leaf[data-asset]').forEach(leaf => {
      leaf.addEventListener('click', (e) => { e.stopPropagation(); showFile(leaf.dataset.asset); });
    });
    root.querySelectorAll('details[data-folder] > summary').forEach(sum => {
      sum.addEventListener('click', () => {
        const fk = sum.parentElement.dataset.folder;
        if (fk) showFolder(fk);
      });
    });
  })();
  </script>
</div>

</body>
</html>
